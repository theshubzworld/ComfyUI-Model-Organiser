# ============================================================
# SimplePod Model Calculator — Environment Variables (EXAMPLE)
# ============================================================
# Copy this file to .env and fill in your tokens.
# Do NOT commit .env — only commit .env.example
# ============================================================

# ── API Tokens ───────────────────────────────────────────────
VITE_HF_TOKEN=hf_YOUR_TOKEN_HERE
VITE_CIVITAI_TOKEN=YOUR_CIVITAI_API_KEY_HERE

# ── Supabase Database (for Vercel cloud deployment) ──────────
# Get these from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Clerk Authentication (optional — skip for local dev) ──────
# Get yours at: https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
