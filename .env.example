# ============================================================
# SimplePod Model Calculator — Environment Variables (EXAMPLE)
# ============================================================
# Copy this file to .env and fill in your tokens.
# Do NOT commit .env — only commit .env.example
# ============================================================

# ── API Tokens (Server Secrets — kept safe on Vercel) ───────
HF_TOKEN=hf_YOUR_TOKEN_HERE
CIVITAI_TOKEN=YOUR_CIVITAI_API_KEY_HERE

# ── Supabase Database & Auth (for Vercel cloud deployment) ──
# Get these from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
